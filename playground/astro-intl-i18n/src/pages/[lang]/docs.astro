---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import DocsSidebar from "../../components/docs/DocsSidebar.astro";
import DocsHero from "../../components/docs/DocsHero.astro";
import DocsInstallation from "../../components/docs/DocsInstallation.astro";
import DocsFileStructure from "../../components/docs/DocsFileStructure.astro";
import DocsConfiguration from "../../components/docs/DocsConfiguration.astro";
import DocsUsage from "../../components/docs/DocsUsage.astro";
import DocsAPI from "../../components/docs/DocsAPI.astro";
import DocsExamples from "../../components/docs/DocsExamples.astro";
import { setRequestLocale, getTranslations } from "astro-intl";
import getRequestConfig from "../../i18n/request";
import "../../styles/global.css";

await setRequestLocale(Astro.url, getRequestConfig);

const tDocs = getTranslations("docs");
const tFooter = getTranslations("footer");

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "es" } },
  ];
}
---

<Layout title={`${tDocs("pageTitle")} — astro-intl`} description={tDocs("pageSubtitle")}>
  <Navigation activePage="docs" />

  <!-- Mobile sidebar overlay -->
  <div
    id="sidebar-overlay"
    class="fixed inset-0 z-40 hidden"
    style="background: rgba(0,0,0,0.6); backdrop-filter: blur(2px);"
  ></div>

  <!-- Mobile sidebar drawer -->
  <aside
    id="sidebar-drawer"
    class="fixed top-0 left-0 z-50 h-full w-72 overflow-y-auto transition-transform duration-300"
    style="background: var(--color-bg-secondary); border-right: 1px solid var(--color-border); transform: translateX(-100%); padding: 1.5rem 1.25rem;"
  >
    <div class="flex items-center justify-between mb-8">
      <span class="text-sm font-semibold" style="color: var(--color-text);">
        astro<span style="color: var(--color-accent);">-intl</span>
      </span>
      <button
        id="sidebar-close"
        class="flex items-center justify-center w-8 h-8 rounded-md transition-colors"
        style="color: var(--color-text-tertiary); border: 1px solid var(--color-border);"
        aria-label="Close menu"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <DocsSidebar />
  </aside>

  <!-- Page body -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-10">

    <!-- Mobile top bar with menu toggle -->
    <div
      class="flex items-center gap-3 mb-6 md:hidden"
      style="padding: 0.625rem 0.875rem; background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: 0.625rem;"
    >
      <button
        id="sidebar-open"
        class="flex items-center gap-2 text-sm font-medium transition-colors w-full"
        style="color: var(--color-text-secondary);"
        aria-label="Open menu"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        {tDocs("sidebar.gettingStarted")}
      </button>
    </div>

    <div class="docs-layout">

      <!-- Desktop sidebar -->
      <aside class="docs-sidebar hidden md:block">
        <DocsSidebar />
      </aside>

      <!-- Main content -->
      <main class="docs-main">
        <DocsHero />
        <DocsInstallation />
        <DocsFileStructure />
        <DocsConfiguration />
        <DocsUsage />
        <DocsAPI />
        <DocsExamples />
      </main>

    </div>
  </div>

  <footer class="py-10 mt-8" style="border-top: 1px solid var(--color-border);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold" style="color: var(--color-text);">astro<span style="color: var(--color-accent);">-intl</span></span>
        <span class="text-xs" style="color: var(--color-text-tertiary);">—</span>
        <span class="text-xs" style="color: var(--color-text-tertiary);">{tFooter("description")}</span>
      </div>
      <p class="text-xs" style="color: var(--color-text-tertiary);" set:html={tFooter.markup("madeWith", {
        heart: (chunks: string) => `<span style="color: #e05c5c;">${chunks}</span>`
      })} />
    </div>
  </footer>
</Layout>

<style is:global>
  .docs-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .docs-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 5.5rem;
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
  }

  .docs-main {
    flex: 1;
    min-width: 0;
    max-width: 100%;
  }

  .docs-main > section:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 3rem;
    margin-bottom: 3rem !important;
  }
  .docs-main > section:last-child {
    margin-bottom: 0 !important;
  }

  /* Ensure code blocks don't overflow on mobile */
  .docs-main pre {
    max-width: 100%;
    overflow-x: auto;
  }

  /* Responsive: stack on small screens */
  @media (max-width: 767px) {
    .docs-layout {
      flex-direction: column;
      gap: 0;
    }
    .docs-main > section:not(:last-child) {
      padding-bottom: 2rem;
      margin-bottom: 2rem !important;
    }
  }
</style>

<script>
  const drawer = document.getElementById("sidebar-drawer")!;
  const overlay = document.getElementById("sidebar-overlay")!;
  const openBtn = document.getElementById("sidebar-open")!;
  const closeBtn = document.getElementById("sidebar-close")!;

  function openSidebar() {
    drawer.style.transform = "translateX(0)";
    overlay.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeSidebar() {
    drawer.style.transform = "translateX(-100%)";
    overlay.classList.add("hidden");
    document.body.style.overflow = "";
  }

  openBtn?.addEventListener("click", openSidebar);
  closeBtn?.addEventListener("click", closeSidebar);
  overlay?.addEventListener("click", closeSidebar);

  // Close drawer when a sidebar link is clicked on mobile
  drawer.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", closeSidebar);
  });
</script>
