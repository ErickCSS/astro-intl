---
import { getTranslations } from "astro-intl";
import CodeBlock from "../CodeBlock.astro";

const t = getTranslations("docs");
---

<section id="configuration" class="mb-14 scroll-mt-24">
  <div class="flex items-center gap-3 mb-8">
    <span class="w-1 h-5 rounded-full" style="background: var(--color-accent);"></span>
    <h2 class="text-xl font-bold" style="color: var(--color-text);">{t("configuration.title")}</h2>
  </div>

  <!-- Step 1: request.ts -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("configuration.requestTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("configuration.requestDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/i18n/request.ts"
      lang="typescript"
      code={'import type { RequestConfig } from "astro-intl";\n\nexport default async function getRequestConfig(\n  locale: string,\n): Promise<RequestConfig> {\n  return {\n    locale,\n    messages: (await import(`./messages/${locale}.json`)).default,\n  };\n}'}
    />
  </div>

  <!-- Step 2: messages -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("configuration.messagesTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("configuration.messagesDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/i18n/messages/en.json"
      lang="json"
      code={`{
  "nav": {
    "home": "Home",
    "docs": "Documentation"
  },
  "hero": {
    "title": "Hello, World!",
    "description": "Welcome to <bold>astro-intl</bold>"
  }
}`}
    />
  </div>

  <!-- Step 3: Layout -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("configuration.layoutTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("configuration.layoutDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/layouts/Layout.astro"
      lang="astro"
      code={'---\nimport { setRequestLocale } from "astro-intl";\nimport getRequestConfig from "../i18n/request";\n\n// Initialize i18n context once for all pages using this layout\nawait setRequestLocale(Astro.url, getRequestConfig);\n---\n\n<!DOCTYPE html>\n<html>\n  <head>\n    <title>My Site</title>\n  </head>\n  <body>\n    <slot />\n  </body>\n</html>'}
    />
  </div>

  <!-- Step 4: getStaticPaths -->
  <div class="mb-2">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("configuration.staticPathsTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("configuration.staticPathsDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/pages/[lang]/index.astro"
      lang="typescript"
      code={`export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "es" } },
  ];
}`}
    />
  </div>
</section>
