---
import { getTranslations } from "astro-intl";

const t = getTranslations("docs");
---

<section id="usage" class="mb-14 scroll-mt-24">
  <div class="flex items-center gap-3 mb-8">
    <span class="w-1 h-5 rounded-full" style="background: var(--color-accent);"></span>
    <h2 class="text-xl font-bold" style="color: var(--color-text);">{t("usage.title")}</h2>
  </div>

  <!-- Basic Translation -->
  <div class="mb-10">
    <h3 class="text-sm font-semibold mb-1" style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;">{t("usage.basicTitle")}</h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.basicDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">src/pages/[lang]/index.astro</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>{`---
import { setRequestLocale, getTranslations } from "astro-intl";
import getRequestConfig from "../../i18n/request";

await setRequestLocale(Astro.url, getRequestConfig);

const tHero = getTranslations("hero");
const tNav  = getTranslations("nav");
---

<h1>{tHero("title")}</h1>
<p>{tHero("description")}</p>
<a href="/">{tNav("home")}</a>`}</code></pre>
    </div>
  </div>

  <!-- Markup Translation -->
  <div class="mb-10">
    <h3 class="text-sm font-semibold mb-1" style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;">{t("usage.markupTitle")}</h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.markupDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="rounded-xl overflow-hidden mb-3" style="border: 1px solid var(--color-border);">
      <div class="flex items-center px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">en.json — message with tags</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>{`{
  "hero": {
    "description": "A <bold>type-safe</bold> solution for <link>Astro</link>"
  }
}`}</code></pre>
    </div>
    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">Component.astro — t.markup()</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>{`---
const tHero = getTranslations("hero");
---

<p set:html={tHero.markup("description", {
  bold: (chunks) => \`<strong>\${chunks}</strong>\`,
  link: (chunks) => \`<a href="https://astro.build">\${chunks}</a>\`,
})} />`}</code></pre>
    </div>
  </div>

  <!-- React -->
  <div class="mb-2">
    <h3 class="text-sm font-semibold mb-1" style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;">{t("usage.reactTitle")}</h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.reactDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">MyComponent.tsx — t.rich()</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>{`import { getTranslationsReact } from "astro-intl";

export default function MyComponent() {
  const t = getTranslationsReact("hero");

  return (
    <p>
      {t.rich("description", {
        bold: (chunks) => <strong>{chunks}</strong>,
        link: (chunks) => <a href="https://astro.build">{chunks}</a>,
      })}
    </p>
  );
}`}</code></pre>
    </div>
  </div>
</section>
