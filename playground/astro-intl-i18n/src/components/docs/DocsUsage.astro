---
import { getTranslations } from "astro-intl";
import CodeBlock from "../CodeBlock.astro";

const t = getTranslations("docs");
---

<section id="usage" class="mb-14 scroll-mt-24">
  <div class="flex items-center gap-3 mb-8">
    <span class="w-1 h-5 rounded-full" style="background: var(--color-accent);"></span>
    <h2 class="text-xl font-bold" style="color: var(--color-text);">{t("usage.title")}</h2>
  </div>

  <!-- Basic Translation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.basicTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.basicDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/pages/[lang]/index.astro"
      lang="astro"
      code={'---\nimport { getTranslations } from "astro-intl";\n\n// No need to call setRequestLocale here - it\'s already in the layout!\nconst tHero = getTranslations("hero");\nconst tNav  = getTranslations("nav");\n---\n\n<h1>{tHero("title")}</h1>\n<p>{tHero("description")}</p>\n<a href="/">{tNav("home")}</a>'}
    />
  </div>

  <!-- Markup Translation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.markupTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.markupDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="mb-3">
      <CodeBlock
        title="en.json — message with tags"
        lang="json"
        code={`{
  "hero": {
    "description": "A <bold>type-safe</bold> solution for <link>Astro</link>"
  }
}`}
      />
    </div>
    <CodeBlock
      title="Component.astro — t.markup()"
      lang="astro"
      code={'---\nconst tHero = getTranslations("hero");\n---\n\n<p set:html={tHero.markup("description", {\n  bold: (chunks) => `<strong>${chunks}</strong>`,\n  link: (chunks) => `<a href="https://astro.build">${chunks}</a>`,\n})} />'}
    />
  </div>

  <!-- React -->
  <div class="mb-2">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.reactTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.reactDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="MyComponent.tsx — t.rich()"
      lang="tsx"
      code={`import { getTranslationsReact } from "astro-intl";

export default function MyComponent() {
  const t = getTranslationsReact("hero");

  return (
    <p>
      {t.rich("description", {
        bold: (chunks) => <strong>{chunks}</strong>,
        link: (chunks) => <a href="https://astro.build">{chunks}</a>,
      })}
    </p>
  );
}`}
    />
  </div>
</section>
