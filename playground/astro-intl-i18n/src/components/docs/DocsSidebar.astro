---
import { getTranslations } from "astro-intl";

const t = getTranslations("docs");

const sections = [
  { id: "installation", label: t("sidebar.installation") },
  { id: "file-structure", label: t("sidebar.fileStructure") },
  { id: "configuration", label: t("sidebar.configuration") },
  { id: "usage", label: t("sidebar.usage") },
  { id: "api", label: t("sidebar.api") },
  { id: "examples", label: t("sidebar.examples") },
];
---

<div style="border-left: 1px solid var(--color-border); padding-left: 0;">
  <p
    class="text-xs font-semibold uppercase tracking-widest mb-3 px-3"
    style="color: var(--color-text-tertiary); letter-spacing: 0.1em;"
  >
    {t("sidebar.gettingStarted")}
  </p>
  <ul class="space-y-0.5">
    {sections.map((s) => (
      <li>
        <a
          href={`#${s.id}`}
          class="sidebar-link block py-2 px-3 text-sm transition-all duration-150 relative"
          data-section={s.id}
          style="color: var(--color-text-tertiary); border-left: 2px solid transparent; margin-left: -1px;"
        >
          {s.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  function initSidebar() {
    const links = document.querySelectorAll<HTMLAnchorElement>(".sidebar-link");
    const sectionEls = Array.from(links).map((l) =>
      document.getElementById(l.dataset.section!)
    );

    function setActive(id: string) {
      links.forEach((l) => {
        const active = l.dataset.section === id;
        l.style.color = active ? "var(--color-accent)" : "var(--color-text-tertiary)";
        l.style.borderLeftColor = active ? "var(--color-accent)" : "transparent";
        l.style.fontWeight = active ? "500" : "400";
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: "-10% 0px -75% 0px" }
    );

    sectionEls.forEach((s) => s && observer.observe(s));
  }

  initSidebar();
  document.addEventListener("astro:page-load", initSidebar);
</script>
