---
import { getTranslations } from "astro-intl";

const t = getTranslations("docs");
---

<section id="installation" class="mb-14 scroll-mt-24">
  <div class="flex items-center gap-3 mb-2">
    <span class="w-1 h-5 rounded-full" style="background: var(--color-accent);"></span>
    <h2 class="text-xl font-bold" style="color: var(--color-text);">{t("installation.title")}</h2>
  </div>
  <p class="text-sm mb-6 ml-4" style="color: var(--color-text-tertiary);">{t("installation.description")}</p>

  <div class="space-y-3 mb-8">
    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center justify-between px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">npm</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>npm install astro-intl</code></pre>
    </div>

    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center justify-between px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">pnpm</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>pnpm add astro-intl</code></pre>
    </div>

    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
      <div class="flex items-center justify-between px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
        <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">yarn</span>
      </div>
      <pre class="rounded-none! border-0! m-0!"><code>yarn add astro-intl</code></pre>
    </div>
  </div>

  <p class="text-sm mb-4" style="color: var(--color-text-secondary);">{t("installation.addIntegration")}</p>

  <div class="rounded-xl overflow-hidden mb-4" style="border: 1px solid var(--color-border);">
    <div class="flex items-center px-4 py-2.5" style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border);">
      <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">astro.config.mjs</span>
    </div>
    <pre class="rounded-none! border-0! m-0!"><code>{`import { defineConfig } from 'astro/config';
import astroIntl from 'astro-intl';

export default defineConfig({
  integrations: [astroIntl()],
});`}</code></pre>
  </div>

  <div
    class="flex items-start gap-3 px-4 py-3 rounded-lg text-sm"
    style="background: var(--color-accent-dim); border: 1px solid var(--color-border-hover); color: var(--color-accent);"
  >
    <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span style="color: var(--color-text-secondary);">{t("installation.integrationNote")}</span>
  </div>
</section>
