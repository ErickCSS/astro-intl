{
  "name": "astro-intl",
  "version": "2.2.0",
  "type": "module",
  "description": "Sistema de internacionalización simple y type-safe para Astro.",
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "withastro",
    "i18n",
    "internationalization",
    "intl",
    "translations",
    "typescript",
    "accessibility",
    "a11y"
  ],
  "author": "Erick Cruz <erickj.cruzs@gmail.com>",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./react": {
      "types": "./dist/adapters/react.d.ts",
      "import": "./dist/adapters/react.js"
    },
    "./svelte": {
      "types": "./dist/adapters/svelte.d.ts",
      "import": "./dist/adapters/svelte.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js"
    },
    "./components": {
      "import": "./dist/components/AutoRedirect.astro"
    }
  },
  "peerDependencies": {
    "astro": "^4 || ^5 || ^6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErickCSS/astro-intl"
  },
  "bugs": {
    "url": "https://github.com/ErickCSS/astro-intl/issues"
  },
  "homepage": "https://github.com/ErickCSS/astro-intl#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@vitest/ui": "^4.1.2",
    "astro": "^6.1.2",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svelte": "^5.55.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
