---
import { getTranslations } from "astro-intl";

const t = getTranslations("docs");
---

<div class="pb-10 mb-10" style="border-bottom: 1px solid var(--color-border);">
  <div
    class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-5"
    style="background: var(--color-accent-dim); border: 1px solid var(--color-border-hover); color: var(--color-accent);"
  >
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>
    {t("hero.badge")}
  </div>

  <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight" style="color: var(--color-text);">
    {t("hero.title")}
    <span style="color: var(--color-accent);"> {t("hero.titleAccent")}</span>
  </h1>

  <p
    class="text-sm md:text-base max-w-2xl leading-relaxed"
    style="color: var(--color-text-secondary);"
    set:html={t.markup("hero.description", {
      bold: (chunks: string) =>
        `<strong style="color: var(--color-accent); font-weight: 600;">${chunks}</strong>`,
    })}
  />
</div>
