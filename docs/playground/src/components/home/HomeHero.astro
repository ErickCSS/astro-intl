---
import CodeTabs from "@/components/CodeTabs.astro";
import InstallTabs from "@/components/InstallTabs.astro";
import { getLocale, getTranslations } from "astro-intl";

const tHero = getTranslations("hero");
const locale = getLocale();
---

<!-- Hero -->
<section class="relative overflow-hidden min-h-[88vh] flex items-center">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(61,139,94,0.18) 0%, transparent 70%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 40% 40% at 80% 80%, rgba(111,207,151,0.06) 0%, transparent 60%);"
  >
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 relative w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column: Content -->
      <div>
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-8"
          style="background: var(--color-accent-dim); border: 1px solid var(--color-border-hover); color: var(--color-accent);"
        >
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background: var(--color-accent);"></span>
          {tHero("badge")}
        </div>
        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight tracking-tight"
          style="color: var(--color-text);"
        >
          {tHero("title")}
          <span class="block" style="color: var(--color-accent);">{tHero("titleAccent")}</span>
        </h1>
        <p class="text-lg md:text-xl mb-4 max-w-xl" style="color: var(--color-text-secondary);">
          {tHero("subtitle")}
        </p>
        <p
          class="text-base mb-10 max-w-xl"
          style="color: var(--color-text-tertiary);"
          set:html={tHero.markup("description", {
            bold: (chunks: string) =>
              `<strong style="color: var(--color-accent); font-weight: 600;">${chunks}</strong>`,
          })}
        />
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={`/${locale}/docs`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all"
            style="background: var(--color-primary); color: var(--color-text);"
          >
            {tHero("getStarted")}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
          <a
            href="https://github.com/ErickCSS/astro-intl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all"
            style="color: var(--color-text-secondary); border: 1px solid var(--color-border);"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path></svg
            >
            GitHub
          </a>
        </div>
        <div class="mt-10">
          <InstallTabs pkg="astro-intl" />
        </div>
      </div>

      <!-- Right Column: Code Example -->
      <div class="hidden lg:block">
        <CodeTabs
          tabs={[
            {
              label: "index.astro",
              lang: "astro",
              code: `---
import { getTranslations } from 'astro-intl';

const t = getTranslations();
---

<h1>{t('welcome')}</h1>
<p>{t('hero.subtitle')}</p>`,
            },
            {
              label: "en.json",
              lang: "json",
              code: `{
  "welcome": "Welcome to astro-intl",
  "hero": {
    "subtitle": "Type-safe i18n for Astro"
  }
}`,
            },
            {
              label: "Output",
              lang: "html",
              code: `<h1>Welcome to astro-intl</h1>
<p>Type-safe i18n for Astro</p>`,
            },
          ]}
        />
      </div>
    </div>
  </div>
</section>
