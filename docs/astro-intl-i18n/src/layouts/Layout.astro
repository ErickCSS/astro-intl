---
import { getLocale } from "astro-intl";
import "flag-icons/css/flag-icons.min.css";

const locale = getLocale();

interface Props {
  title?: string;
  description?: string;
}

const { title = "Astro-intl", description = "Simple and powerful internationalization for Astro" } =
  Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/logo-astro-intl.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
