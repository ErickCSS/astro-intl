---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import CodeTabs from "@/components/CodeTabs.astro";
import { getTranslations, getLocale } from "astro-intl";

import "@/styles/global.css";

const tHero = getTranslations("hero");
const tFeatures = getTranslations("features");
const tFooter = getTranslations("footer");
const locale = getLocale();

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}
---

<Layout
  title="Astro-intl — Simple and Powerful i18n for Astro"
  description="Type-safe internationalization library for Astro. No props drilling, dynamic loading, namespaces support, and rich text formatting. Inspired by next-intl."
  keywords={[
    "astro i18n",
    "astro internationalization",
    "astro localization",
    "type-safe i18n",
    "next-intl",
    "astro translation",
    "multilingual astro",
  ]}
>
  <Navigation activePage="home" />

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[88vh] flex items-center">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(61,139,94,0.18) 0%, transparent 70%);"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 40% 40% at 80% 80%, rgba(111,207,151,0.06) 0%, transparent 60%);"
    >
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 relative w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left Column: Content -->
        <div>
          <div
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-8"
            style="background: var(--color-accent-dim); border: 1px solid var(--color-border-hover); color: var(--color-accent);"
          >
            <span class="w-1.5 h-1.5 rounded-full inline-block" style="background: var(--color-accent);"
            ></span>
            {tHero("badge")}
          </div>
          <h1
            class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight tracking-tight"
            style="color: var(--color-text);"
          >
            {tHero("title")}
            <span class="block" style="color: var(--color-accent);">{tHero("titleAccent")}</span>
          </h1>
          <p class="text-lg md:text-xl mb-4 max-w-xl" style="color: var(--color-text-secondary);">
            {tHero("subtitle")}
          </p>
          <p
            class="text-base mb-10 max-w-xl"
            style="color: var(--color-text-tertiary);"
            set:html={tHero.markup("description", {
              bold: (chunks: string) =>
                `<strong style="color: var(--color-accent); font-weight: 600;">${chunks}</strong>`,
            })}
          />
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={`/${locale}/docs`}
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all"
              style="background: var(--color-primary); color: var(--color-text);"
            >
              {tHero("getStarted")}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </a>
            <a
              href="https://github.com/ErickCSS/astro-intl"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all"
              style="color: var(--color-text-secondary); border: 1px solid var(--color-border);"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                ></path></svg
              >
              GitHub
            </a>
          </div>
          <div
            class="mt-10 inline-flex items-center gap-3 px-4 py-2.5 rounded-lg"
            style="background: var(--color-bg-tertiary); border: 1px solid var(--color-border);"
          >
            <span class="text-xs font-mono" style="color: var(--color-text-tertiary);">$</span>
            <code
              style="background: transparent; border: none; padding: 0; color: var(--color-accent); font-size: 0.85rem;"
              >npm install astro-intl</code
            >
          </div>
        </div>

        <!-- Right Column: Code Example -->
        <div class="hidden lg:block">
          <CodeTabs
            tabs={[
              {
                label: "index.astro",
                lang: "astro",
                code: `---
import { getTranslations } from 'astro-intl';

const t = getTranslations();
---

<h1>{t('welcome')}</h1>
<p>{t('hero.subtitle')}</p>`,
              },
              {
                label: "en.json",
                lang: "json",
                code: `{
  "welcome": "Welcome to astro-intl",
  "hero": {
    "subtitle": "Type-safe i18n for Astro"
  }
}`,
              },
              {
                label: "Output",
                lang: "html",
                code: `<h1>Welcome to astro-intl</h1>
<p>Type-safe i18n for Astro</p>`,
              },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-24 bg-bg-secondary">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-3" style="color: var(--color-text);">
          {tFeatures("title")}
        </h2>
        <p class="text-base" style="color: var(--color-text-tertiary);">{tFeatures("subtitle")}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("noPropsDrilling.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("noPropsDrilling.description")}
          </p>
        </div>
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("typeSafe.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("typeSafe.description")}
          </p>
        </div>
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("dynamicLoading.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("dynamicLoading.description")}
          </p>
        </div>
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("namespaces.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("namespaces.description")}
          </p>
        </div>
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"
              ></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("richText.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("richText.description")}
          </p>
        </div>
        <div
          class="p-6 rounded-xl transition-all"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style="background: var(--color-accent-dim);"
          >
            <svg
              class="w-5 h-5"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg
            >
          </div>
          <h3 class="text-base font-semibold mb-1.5" style="color: var(--color-text);">
            {tFeatures("simple.title")}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
            {tFeatures("simple.description")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-2xl p-10 md:p-14 text-center relative overflow-hidden"
        style="background: var(--color-bg-secondary); border: 1px solid var(--color-border-hover);"
      >
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(61,139,94,0.12) 0%, transparent 70%);"
        >
        </div>
        <div class="relative">
          <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--color-text);">
            {tHero("ctaTitle")}
          </h2>
          <p class="text-base mb-8 max-w-lg mx-auto" style="color: var(--color-text-tertiary);">
            {tHero("ctaSubtitle")}
          </p>
          <a
            href={`/${locale}/docs`}
            class="inline-flex items-center gap-2 px-7 py-3 rounded-lg font-semibold text-sm transition-all"
            style="background: var(--color-primary); color: var(--color-text);"
          >
            {tHero("getStarted")}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-10" style="border-top: 1px solid var(--color-border);">
    <div
      class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold" style="color: var(--color-text);"
          >astro<span style="color: var(--color-accent);">-intl</span></span
        >
        <span class="text-xs" style="color: var(--color-text-tertiary);">—</span>
        <span class="text-xs" style="color: var(--color-text-tertiary);">{tFooter("description")}</span>
      </div>
      <div class="flex flex-col md:flex-row items-center gap-3">
        <a
          href="https://buymeacoffee.com/erickcs"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs transition-colors"
          style="color: var(--color-text-tertiary);"
        >
          ☕ Buy me a coffee
        </a>
        <p
          class="text-xs"
          style="color: var(--color-text-tertiary);"
          set:html={tFooter.markup("madeWith", {
            heart: (chunks: string) => `<span style="color: #e05c5c;">${chunks}</span>`,
            link: (chunks: string) =>
              `<a href="https://erickcs.com" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent); text-decoration: none; font-weight: 500;">${chunks}</a>`,
          })}
        />
      </div>
    </div>
  </footer>
</Layout>
