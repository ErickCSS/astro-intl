---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import HomeHero from "@/components/home/HomeHero.astro";
import HomeFeatures from "@/components/home/HomeFeatures.astro";
import HomeFrameworks from "@/components/home/HomeFrameworks.astro";
import HomeCommunity from "@/components/home/HomeCommunity.astro";
import HomeCTA from "@/components/home/HomeCTA.astro";
import HomeFooter from "@/components/home/HomeFooter.astro";

import "@/styles/global.css";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}
---

<Layout
  title="Astro-intl — Simple and Powerful i18n for Astro"
  description="Type-safe internationalization library for Astro. No props drilling, dynamic loading, namespaces support, and rich text formatting. Inspired by next-intl."
  keywords={[
    "astro i18n",
    "astro internationalization",
    "astro localization",
    "type-safe i18n",
    "next-intl",
    "astro translation",
    "multilingual astro",
  ]}
>
  <Navigation activePage="home" />
  <HomeHero />
  <HomeFeatures />
  <HomeFrameworks />
  <HomeCommunity />
  <HomeCTA />
  <HomeFooter />
</Layout>
