---
import DocsLayout from "@/layouts/DocsLayout.astro";
import DocsHero from "@/components/docs/DocsHero.astro";
import { getTranslations, getLocale } from "astro-intl";

const t = getTranslations("docs");
const locale = getLocale();
const base = `/${locale}/docs`;

const cards = [
  { href: `${base}/installation`, title: t("sidebar.installation"), description: t("cards.installation"), icon: "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" },
  { href: `${base}/configuration`, title: t("sidebar.configuration"), description: t("cards.configuration"), icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
  { href: `${base}/usage`, title: t("sidebar.usage"), description: t("cards.usage"), icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" },
  { href: `${base}/routing`, title: t("sidebar.routing"), description: t("cards.routing"), icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" },
  { href: `${base}/react`, title: t("sidebar.frameworks"), description: t("cards.frameworks"), icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
  { href: `${base}/api`, title: t("sidebar.api"), description: t("cards.api"), icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
  { href: `${base}/examples`, title: t("sidebar.examples"), description: t("cards.examples"), icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" },
];

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}
---

<DocsLayout>
  <DocsHero />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-10">
    {
      cards.map((card) => (
        <a
          href={card.href}
          class="group p-5 rounded-xl transition-all duration-200"
          style="background: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
              style="background: var(--color-accent-dim);"
            >
              <svg
                class="w-4 h-4"
                style="color: var(--color-accent);"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d={card.icon}
                />
              </svg>
            </div>
            <h3
              class="text-sm font-semibold group-hover:translate-x-0.5 transition-transform"
              style="color: var(--color-text);"
            >
              {card.title}
            </h3>
          </div>
          <p class="text-xs leading-relaxed" style="color: var(--color-text-tertiary);">
            {card.description}
          </p>
          <div class="flex items-center gap-1 mt-3">
            <svg
              class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform"
              style="color: var(--color-accent);"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </div>
        </a>
      ))
    }
  </div>
</DocsLayout>
