---
import { LANGUAGES, DEFAULT_LOCALE } from "../i18n/ui";
const locales = Object.keys(LANGUAGES);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>astro-intl — Type-safe i18n for Astro</title>
    <meta
      name="description"
      content="Type-safe internationalization library for Astro. Redirecting to your language..."
    />
    <meta name="robots" content="noindex, follow" />
    <link rel="icon" type="image/svg+xml" href="/logo-astro-intl.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        height: 100%;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Outfit", sans-serif;
        overflow: hidden;
      }

      .scene {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.5rem;
        animation: fadeIn 0.6s ease forwards;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: scale(0.95);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }

      .blackhole {
        position: relative;
        width: 180px;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .ring {
        position: absolute;
        border-radius: 50%;
        border: 2px solid transparent;
        animation: spin linear infinite;
      }
      .ring:nth-child(1) {
        width: 180px;
        height: 180px;
        border-top-color: #f97316;
        border-right-color: #f9731640;
        animation-duration: 3s;
        filter: blur(1px);
      }
      .ring:nth-child(2) {
        width: 148px;
        height: 148px;
        border-top-color: #fb923c;
        border-left-color: #fb923c60;
        animation-duration: 2.2s;
        animation-direction: reverse;
        filter: blur(0.5px);
      }
      .ring:nth-child(3) {
        width: 118px;
        height: 118px;
        border-top-color: #fbbf24;
        border-right-color: #fbbf2450;
        animation-duration: 1.6s;
        filter: blur(0.5px);
      }
      .ring:nth-child(4) {
        width: 90px;
        height: 90px;
        border-top-color: #fff7ed80;
        animation-duration: 1.1s;
        animation-direction: reverse;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .core {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #1a1a1a, #000);
        box-shadow:
          0 0 20px 8px #00000099,
          0 0 40px 16px #000000cc,
          inset 0 0 12px #000;
        z-index: 2;
      }

      .glow {
        position: absolute;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: radial-gradient(circle, #f9731608 0%, transparent 70%);
        animation: pulse 2.4s ease-in-out infinite;
      }

      @keyframes pulse {
        0%,
        100% {
          transform: scale(1);
          opacity: 0.6;
        }
        50% {
          transform: scale(1.1);
          opacity: 1;
        }
      }

      .brand {
        text-align: center;
        color: #fff;
        letter-spacing: 0.08em;
      }
      .brand h1 {
        font-size: 1.6rem;
        font-weight: 900;
        text-transform: uppercase;
        background: linear-gradient(90deg, #f97316, #fbbf24, #f97316);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: shimmer 2.5s linear infinite;
      }
      .brand p {
        font-size: 0.75rem;
        font-weight: 400;
        color: #ffffff50;
        margin-top: 0.3rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      @keyframes shimmer {
        to {
          background-position: 200% center;
        }
      }
    </style>
    <script define:vars={{ locales, DEFAULT_LOCALE }}>
      const lang = (navigator.language || navigator.languages?.[0] || "").slice(0, 2).toLowerCase();
      const locale = locales.includes(lang) ? lang : DEFAULT_LOCALE;
      window.location.replace("/" + locale);
    </script>
  </head>
  <body>
    <div class="scene">
      <div class="blackhole">
        <div class="glow"></div>
        <div class="ring"></div>
        <div class="ring"></div>
        <div class="ring"></div>
        <div class="ring"></div>
        <div class="core"></div>
      </div>
      <div class="brand">
        <h1>Black Hole Tracking</h1>
        <p>Entering the event horizon</p>
      </div>
    </div>
  </body>
</html>
