---
import { getTranslations } from "astro-intl";
import CodeBlock from "../CodeBlock.astro";

const t = getTranslations("docs");
---

<section id="usage" class="mb-14 scroll-mt-24">
  <div class="flex items-center gap-3 mb-8">
    <span class="w-1 h-5 rounded-full" style="background: var(--color-accent);"></span>
    <h2 class="text-xl font-bold" style="color: var(--color-text);">{t("usage.title")}</h2>
  </div>

  <!-- Basic Translation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.basicTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.basicDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="src/pages/[lang]/index.astro"
      lang="astro"
      code={'---\nimport { getTranslations } from "astro-intl";\n\n// No need to call setRequestLocale here - it\'s already in the layout!\nconst tHero = getTranslations("hero");\nconst tNav  = getTranslations("nav");\n---\n\n<h1>{tHero("title")}</h1>\n<p>{tHero("description")}</p>\n<a href="/">{tNav("home")}</a>'}
    />
  </div>

  <!-- Interpolation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.interpolationTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.interpolationDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="mb-3">
      <CodeBlock
        title="en.json — message with variables"
        lang="json"
        code={`{
  "hero": {
    "greeting": "Hello, {name}!",
    "info": "You have {count} new messages"
  }
}`}
      />
    </div>
    <CodeBlock
      title="Component.astro — t() with values"
      lang="astro"
      code={`---
const tHero = getTranslations("hero");
---

<p>{tHero("greeting", { name: "John" })}</p>
<!-- "Hello, John!" -->

<p>{tHero("info", { count: 5 })}</p>
<!-- "You have 5 new messages" -->

<p>{tHero("greeting")}</p>
<!-- "Hello, {name}!" — placeholder kept when no values -->`}
    />
  </div>

  <!-- Markup Translation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.markupTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.markupDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="mb-3">
      <CodeBlock
        title="en.json — message with tags"
        lang="json"
        code={`{
  "hero": {
    "description": "A <bold>type-safe</bold> solution for <link>Astro</link>"
  }
}`}
      />
    </div>
    <CodeBlock
      title="Component.astro — t.markup()"
      lang="astro"
      code={'---\nconst tHero = getTranslations("hero");\n---\n\n<p set:html={tHero.markup("description", {\n  bold: (chunks) => `<strong>${chunks}</strong>`,\n  link: (chunks) => `<a href="https://astro.build">${chunks}</a>`,\n})} />'}
    />
  </div>

  <!-- Markup + Interpolation -->
  <div class="mb-10">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.markupInterpolationTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.markupInterpolationDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <div class="mb-3">
      <CodeBlock
        title="en.json — variables + tags"
        lang="json"
        code={`{
  "hero": {
    "welcome": "Hello {name}, read our <link>docs</link> to get started"
  }
}`}
      />
    </div>
    <CodeBlock
      title="Component.astro — t.markup() with values"
      lang="astro"
      code={'---\nconst tHero = getTranslations("hero");\n---\n\n<p set:html={tHero.markup("welcome", {\n  values: { name: "John" },\n  tags: {\n    link: (chunks) => `<a href="/docs">${chunks}</a>`,\n  }\n})} />\n<!-- "Hello John, read our <a href="/docs">docs</a> to get started" -->'}
    />
  </div>

  <!-- Raw Values -->
  <div class="mb-6">
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.rawTitle")}
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.rawDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />

    <!-- Arrays Example -->
    <div class="mb-4">
      <h4 class="text-sm font-semibold mb-1" style="color: var(--color-text);">
        {t("usage.rawArraysTitle")}
      </h4>
      <p
        class="text-sm mb-2"
        style="color: var(--color-text-tertiary);"
        set:html={t.markup("usage.rawArraysDescription", {
          code: (c: string) => `<code>${c}</code>`,
        })}
      />
      <CodeBlock
        title="messages/en.json"
        lang="json"
        code={`{\n  "features": ["Fast", "Lightweight", "Type-safe"]\n}`}
      />
      <CodeBlock
        title="Component.astro"
        lang="astro"
        code={`---\nimport { getTranslations } from "astro-intl";\nconst t = getTranslations();\n\n// Get raw array\nconst features = t.raw("features") as string[];\n// features = ["Fast", "Lightweight", "Type-safe"]\n---\n\n<ul>\n  &#123;features.map(feature => &lt;li&gt;&#123;feature&#125;&lt;/li&gt;)&#125;\n&lt;/ul&gt;`}
      />
    </div>

    <!-- Objects Example -->
    <div class="mb-4">
      <h4 class="text-sm font-semibold mb-1" style="color: var(--color-text);">
        {t("usage.rawObjectsTitle")}
      </h4>
      <p
        class="text-sm mb-2"
        style="color: var(--color-text-tertiary);"
        set:html={t.markup("usage.rawObjectsDescription", {
          code: (c: string) => `<code>${c}</code>`,
        })}
      />
      <CodeBlock
        title="messages/en.json"
        lang="json"
        code={`{\n  "theme": {\n    "primary": "#3b82f6",\n    "secondary": "#64748b"\n  }\n}`}
      />
      <CodeBlock
        title="Component.astro"
        lang="astro"
        code={`---\nconst theme = t.raw("theme") as { primary: string; secondary: string };\n// theme = { primary: "#3b82f6", secondary: "#64748b" }\n---\n\n&lt;div style={\`background: &#36;{theme.primary}\`}&gt;...&lt;/div&gt;`}
      />
    </div>

    <!-- Numbers Example -->
    <div class="mb-2">
      <h4 class="text-sm font-semibold mb-1" style="color: var(--color-text);">
        {t("usage.rawNumbersTitle")}
      </h4>
      <p
        class="text-sm mb-2"
        style="color: var(--color-text-tertiary);"
        set:html={t.markup("usage.rawNumbersDescription", {
          code: (c: string) => `<code>${c}</code>`,
        })}
      />
      <CodeBlock
        title="messages/en.json"
        lang="json"
        code={`{\n  "config": {\n    "maxItems": 100,\n    "timeout": 30\n  }\n}`}
      />
      <CodeBlock
        title="Component.astro"
        lang="astro"
        code={`---\nconst maxItems = t.raw("config.maxItems") as number;\n// maxItems = 100 (number, not string)\n\n// Can use for calculations\nconst limit = maxItems * 0.8; // 80\n---`}
      />
    </div>
  </div>

  <!-- React (deprecated) -->
  <div class="mb-2">
    <div
      class="flex items-start gap-3 px-4 py-3 rounded-lg text-sm mb-4"
      style="background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.25); color: #fbbf24;"
    >
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.832c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"
        ></path>
      </svg>
      <div>
        <span
          style="color: var(--color-text-secondary);"
          set:html={t.markup("usage.reactDeprecated", {
            code: (c: string) => `<code>${c}</code>`,
          })}
        />
        <a
          href={`/${Astro.params.lang}/docs/react`}
          class="inline-flex items-center gap-1 text-xs font-medium mt-1"
          style="color: var(--color-accent);"
        >
          {t("usage.reactDeprecatedLink")}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"
            ></path>
          </svg>
        </a>
      </div>
    </div>
    <h3
      class="text-sm font-semibold mb-1"
      style="color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"
    >
      {t("usage.reactTitle")}
      <span
        class="ml-2 text-xs px-2 py-0.5 rounded-full"
        style="background: rgba(251,191,36,0.15); color: #fbbf24; font-weight: 600; text-transform: none; letter-spacing: 0;"
        >Deprecated</span
      >
    </h3>
    <p
      class="text-sm mb-4"
      style="color: var(--color-text-tertiary);"
      set:html={t.markup("usage.reactDescription", {
        code: (c: string) => `<code>${c}</code>`,
      })}
    />
    <CodeBlock
      title="MyComponent.tsx — t.rich()"
      lang="tsx"
      code={`import { getTranslationsReact } from "astro-intl";

export default function MyComponent() {
  const t = getTranslationsReact("hero");

  return (
    <p>
      {t.rich("description", {
        bold: (chunks) => <strong>{chunks}</strong>,
        link: (chunks) => <a href="https://astro.build">{chunks}</a>,
      })}
    </p>
  );
}`}
    />
  </div>
</section>
