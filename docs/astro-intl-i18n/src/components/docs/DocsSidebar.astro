---
import { getTranslations, getLocale } from "astro-intl";

const t = getTranslations("docs");
const locale = getLocale();
const base = `/${locale}/docs`;

const currentPath = Astro.url.pathname.replace(/\/$/, "");

const groups = [
  {
    label: t("sidebar.gettingStarted"),
    items: [
      { href: `${base}/installation`, label: t("sidebar.installation") },
      { href: `${base}/file-structure`, label: t("sidebar.fileStructure") },
      { href: `${base}/configuration`, label: t("sidebar.configuration") },
    ],
  },
  {
    label: t("sidebar.usageGroup"),
    items: [
      { href: `${base}/usage`, label: t("sidebar.usage") },
      { href: `${base}/routing`, label: t("sidebar.routing") },
      { href: `${base}/auto-redirect`, label: t("sidebar.autoRedirect") },
      { href: `${base}/examples`, label: t("sidebar.examples") },
    ],
  },
  {
    label: t("sidebar.frameworks"),
    items: [
      { href: `${base}/react`, label: t("sidebar.react"), icon: "/Frameworks/react_dark.svg" },
      { href: `${base}/svelte`, label: t("sidebar.svelte"), icon: "/Frameworks/svelte.svg" },
    ],
  },
  {
    label: t("sidebar.reference"),
    items: [{ href: `${base}/api`, label: t("sidebar.api") }],
  },
];
---

<div style="border-left: 1px solid var(--color-border); padding-left: 0;">
  {
    groups.map((group) => (
      <div class="mb-5">
        <p
          class="text-xs font-semibold uppercase tracking-widest mb-2 px-3"
          style="color: var(--color-text-tertiary); letter-spacing: 0.1em;"
        >
          {group.label}
        </p>
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const isActive = currentPath === item.href.replace(/\/$/, "");
            return (
              <li>
                <a
                  href={item.href}
                  class="sidebar-link flex items-center gap-2 py-2 px-3 text-sm transition-all duration-150 relative"
                  style={`color: ${isActive ? "var(--color-accent)" : "var(--color-text-tertiary)"}; border-left: 2px solid ${isActive ? "var(--color-accent)" : "transparent"}; margin-left: -1px; font-weight: ${isActive ? "500" : "400"};`}
                >
                  {(item as any).icon && (
                    <img src={(item as any).icon} alt="" class="w-4 h-4" style="opacity: 0.7;" />
                  )}
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</div>
