---
import { getTranslations, getLocale } from "astro-intl";
import LanguageSelector from "./LanguageSelector.astro";

const t = getTranslations("nav");
const locale = getLocale();

interface Props {
  activePage?: "home" | "docs";
}
const { activePage = "home" } = Astro.props;
---

<nav class="border-b sticky top-0 z-40" style="border-color: var(--color-border); background: rgba(13,20,16,0.92); backdrop-filter: blur(14px);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-8">
        <a href={`/${locale}`} class="flex items-center gap-2 group">
          <div class="w-7 h-7 rounded-md flex items-center justify-center" style="background: var(--color-accent-dim); border: 1px solid var(--color-border-hover);">
            <svg class="w-4 h-4" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
            </svg>
          </div>
          <span class="text-base font-semibold tracking-tight" style="color: var(--color-text);">
            astro<span style="color: var(--color-accent);">-intl</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-1">
          <a
            href={`/${locale}`}
            class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors"
            style={activePage === "home"
              ? "color: var(--color-accent); background: var(--color-accent-dim);"
              : "color: var(--color-text-secondary);"}
          >
            {t("home")}
          </a>
          <a
            href={`/${locale}/docs`}
            class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors"
            style={activePage === "docs"
              ? "color: var(--color-accent); background: var(--color-accent-dim);"
              : "color: var(--color-text-secondary);"}
          >
            {t("docs")}
          </a>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/ErickCSS/astro-intl"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors"
          style="color: var(--color-text-tertiary); border: 1px solid var(--color-border);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
        <LanguageSelector />
        <!-- Mobile hamburger -->
        <button
          id="nav-mobile-toggle"
          class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg transition-colors"
          style="color: var(--color-text-secondary); border: 1px solid var(--color-border);"
          aria-label="Toggle menu"
        >
          <svg id="nav-hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="nav-close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav menu -->
  <div
    id="nav-mobile-menu"
    class="md:hidden hidden"
    style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border);"
  >
    <div class="px-4 py-4 space-y-1">
      <a
        href={`/${locale}`}
        class="block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors"
        style={activePage === "home"
          ? "color: var(--color-accent); background: var(--color-accent-dim);"
          : "color: var(--color-text-secondary);"}
      >
        {t("home")}
      </a>
      <a
        href={`/${locale}/docs`}
        class="block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors"
        style={activePage === "docs"
          ? "color: var(--color-accent); background: var(--color-accent-dim);"
          : "color: var(--color-text-secondary);"}
      >
        {t("docs")}
      </a>
      <a
        href="https://github.com/ErickCSS/astro-intl"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors"
        style="color: var(--color-text-secondary);"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  function initMobileNav() {
    const toggle = document.getElementById("nav-mobile-toggle");
    const menu = document.getElementById("nav-mobile-menu");
    const hamburger = document.getElementById("nav-hamburger-icon");
    const closeIcon = document.getElementById("nav-close-icon");
    if (!toggle || !menu || !hamburger || !closeIcon) return;

    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden", isOpen);
      hamburger.classList.toggle("hidden", !isOpen);
      closeIcon.classList.toggle("hidden", isOpen);
    });
  }
  initMobileNav();
  document.addEventListener("astro:page-load", initMobileNav);
</script>
